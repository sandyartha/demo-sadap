<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "Article",
  {{- range (.GetTerms "authors") }}
  "author": {
    "name" : "{{ .LinkTitle | default .Site.Params.authors }}",
    "url": "{{.Permalink}}"
  },
  {{ end }}
  "headline": "{{ .Title }}",
  "description": "{{ .Params.description }}",
  "wordCount": {{ .WordCount }},
  "datePublished" : "{{ .Date.Format "2006-01-02T15:04:05" }}",
  "dateModified" : "{{ .Page.Lastmod.Format "2006-01-02T15:04:05"  }}",
  "image" : {
      "@context": "http://schema.org",
      "@type": "ImageObject",
      "url": "https://amwvhnslqo.cloudimg.io/v7/{{ .Params.thumbnail | default "/default.png" | absURL }}?w=1200&h=675",
      "datePublished": "{{ .Date.Format "2006-01-02T15:04:05" }}",
      "name": "{{ .Title }}",
      "height" : 500,
      "width" : 800
    },
  "mainEntityOfPage" : "{{ with .OutputFormats.Get "HTML" }}{{ .Permalink }}{{ end }}",
  "publisher" : {
    "@type": "Organization",
    "name" : "{{ $.Site.Title }}",
    "logo" : {
        "@type" : "ImageObject",
        "url" : "{{ $.Site.Params.siteLogo | absURL }}",
        "height" : 60,
        "width" : 600
    }
  }
}
</script>